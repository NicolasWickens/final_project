<h2>WELCOME, ADMINISTRATOR</h2>

<% if ( success ) { %>

<div style="background: limegreen; color: white; display: inline-block">
  Product created successfully.
</div>

<% } %>

<table>

  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Price</th>
    </tr>
  </thead>

  <tbody>

    <% products.forEach(product => { %>

    <tr>
      <td><%= product.id %></td>
      <td>
        <a href="/products/<%= product.id %>">
          <%= product.name %>
        </a>
      </td>
      <td>$<%= product.price %></td>
      <td>
        <a href="/products/edit/<%= product.id %>">Edit</a>
        <a href="/products/delete/<%= product.id %>">Delete</a>
      </td>
    </tr>

    <% }) %>

  </tbody>
  <% if (page > 1) { %>
  <a href="/products?search=<%= search %>&minPrice=<%= minPrice %>&page=<%= page - 1 %>&nameAsc=<%= nameAsc %>&priceAsc=<%= priceAsc %>">Previous</a>
  <% } %>
  <nav>
    <% for ( let i = 1; i <= totalPages; i++ ) { %>
    <% if(i === page) { %>

    <p>
      Showing page
      <%= page %>
      of
      <%= totalPages %>
    </p>

    <% } else { %>

    <a href="/products?search=<%= search %>&minPrice=<%= minPrice %>&page=<%= i %>&nameAsc=<%= nameAsc %>&priceAsc=<%= priceAsc %>">
      <%= i %>
    </a>

    <% } %>
    <% } %>
  </nav>
  <% if (page < totalPages) { %>
  <a href="/products?search=<%= search %>&minPrice=<%= minPrice %>&page=<%= page + 1 %>&nameAsc=<%= nameAsc %>&priceAsc=<%= priceAsc %>">Next</a>
  <% } %>

</table>

<table>
  <thead>
	<tr>
	  <th>ID</th>
	  <th>Email</th>
	  <th>Role</th>
	</tr>
  </thead>

  <tbody>

	<% users.forEach(user => { %>

	<tr>
	  <td><%= user.id %></td>
	  <td><%= user.email %></td>
	  <td><%= user.role %></td>
	  <td>
		<a href="/users/edit/<%= user.id %>">Edit</a>
		<a href="/users/delete/<%= user.id %>">Delete</a>
	  </td>
	</tr>

	<% }) %>

  </tbody>
</table>